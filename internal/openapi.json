{
    "openapi": "3.1.0",
    "info": {
      "title": "Headless AI Document Engine API",
      "description": "Full API for external LLMs to create documents and append rich blocks rendered in Next.js UI.",
      "version": "1.0.0"
    },
    "servers": [
      {
        "url": "https://striking-earthly-denial.ngrok-free.dev/api/v1",
        "description": "Secure Local Tunnel Server"
      }
    ],
    "paths": {
      "/documents": {
        "post": {
          "summary": "Create a new document container",
          "operationId": "createDocument",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { 
                      "type": "string", 
                      "description": "Optional client-side UUID. Server autogenerates one if omitted." 
                    },
                    "title": { 
                      "type": "string", 
                      "example": "Go & Next.js Architecture" 
                    },
                    "user_id": { 
                      "type": "string", 
                      "example": "usr_123" 
                    }
                  },
                  "required": ["title"]
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Document created successfully.",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string", "example": "bd65536a-b925-4bf0-a6fe-0cf1cb585567" },
                      "user_id": { "type": "string", "example": "usr_123" },
                      "title": { "type": "string", "example": "Go & Next.js Architecture" },
                      "url": { "type": "string", "example": "http://localhost:3000/documents/bd65536a-b925-4bf0-a6fe-0cf1cb585567" },
                      "block_order": { 
                        "type": "array", 
                        "items": { "type": "string" } 
                      },
                      "created_at": { "type": "string", "format": "date-time" },
                      "updated_at": { "type": "string", "format": "date-time" }
                    },
                    "required": ["id", "title", "url"]
                  }
                }
              }
            }
          }
        }
      },
      "/documents/{id}": {
        "get": {
          "summary": "Get full document with hydrated blocks for UI rendering",
          "operationId": "getDocumentWithBlocks",
          "parameters": [
            {
              "name": "id",
              "in": "path",
              "required": true,
              "schema": { "type": "string" }
            }
          ],
          "responses": {
            "200": {
              "description": "Hydrated document response for Next.js frontend."
            }
          }
        }
      },
      "/blocks": {
        "post": {
          "summary": "Add a content block to an existing document",
          "operationId": "createBlock",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "document_id": { 
                      "type": "string", 
                      "description": "UUID of target document" 
                    },
                    "type": { 
                      "type": "string", 
                      "enum": ["heading", "paragraph", "code", "list"],
                      "description": "The visual block type to render in Next.js"
                    },
                    "content": {
                      "type": "object",
                      "description": "Full JSON payload required by Next.js components to render this block.",
                      "properties": {
                        "text": { 
                          "type": "string", 
                          "description": "Text content for heading, paragraph, or code." 
                        },
                        "level": { 
                          "type": "integer", 
                          "description": "Heading level (1, 2, or 3) if type is heading", 
                          "example": 2 
                        },
                        "language": { 
                          "type": "string", 
                          "description": "Programming language (e.g., 'go', 'typescript') if type is code", 
                          "example": "go" 
                        },
                        "items": { 
                          "type": "array", 
                          "items": { "type": "string" }, 
                          "description": "Array of list string items if type is list", 
                          "example": ["Item 1", "Item 2"] 
                        }
                      },
                      "required": ["text"]
                    }
                  },
                  "required": ["document_id", "type", "content"]
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Block appended successfully."
            }
          }
        }
      },
      "/blocks/batch": {
        "post": {
            "summary": "Batch create blocks",
            "operationId": "batchCreateBlocks",
            "requestBody": {
            "required": true,
            "content": {
                "application/json": {
                "schema": {
                    "$ref": "#/components/schemas/BatchCreateBlocksRequest"
                }
                }
            }
            },
            "responses": {
            "201": {
                "description": "Blocks created successfully.",
                "content": {
                "application/json": {
                    "schema": {
                    "$ref": "#/components/schemas/BatchCreateBlocksResponse"
                    }
                }
                }
            }
            }
          }
        }
    }
  }